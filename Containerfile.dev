# Containerfile.dev — bePrepared development container
# Runtime: Node.js 22 (kept as base for ecosystem compat) + Bun (api, worker, frontend, shared)
# Workflow: source is baked in at build time; servers auto-start on container start.
#   Rebuild: ./dev.sh
#   Exec:    podman exec -it beprepared-dev bun run db:migrate

FROM docker.io/library/node:22-alpine

WORKDIR /app

# Install Bun
RUN npm install -g bun

# Copy workspace manifests first for layer caching
COPY package.json bun.lock* ./
COPY api/package.json     ./api/
COPY frontend/package.json ./frontend/
COPY shared/package.json  ./shared/
COPY worker/package.json  ./worker/
COPY e2e/package.json     ./e2e/

# Install all workspace dependencies
RUN bun install --frozen-lockfile

# Copy full source after deps so dep layer is cached on source-only changes
COPY . .

# Make startup script executable
RUN chmod +x /app/scripts/start-dev.sh

# Auto-start all dev servers; use podman exec for one-off commands (migrate, test, etc.)
CMD ["/app/scripts/start-dev.sh"]
