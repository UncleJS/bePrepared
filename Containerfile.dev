# Containerfile.dev — bePrepared development container
#
# Source is copied into the image at build time. No bind mounts are used.

FROM mcr.microsoft.com/playwright:v1.54.2-noble

ENV HOME=/root
ENV PATH=/root/.bun/bin:/usr/local/bin:/usr/bin:/bin
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
ENV NEXT_TELEMETRY_DISABLED=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      bash \
      ca-certificates \
      git \
      procps \
      python3 \
      ripgrep \
      unzip \
      wget && \
    rm -rf /var/lib/apt/lists/*

RUN wget -qO- https://bun.sh/install | bash

WORKDIR /workspace

COPY package.json bun.lock ./
COPY api/package.json ./api/
COPY frontend/package.json ./frontend/
COPY worker/package.json ./worker/
COPY shared/package.json ./shared/
COPY e2e/package.json ./e2e/

RUN bun install

COPY . .

CMD ["bash", "-lc", "while true; do sleep 3600; done"]
