    "mysql2": "^3.11.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "bun-types": "latest",
    "@types/bcryptjs": "^2.4.6"
  }
