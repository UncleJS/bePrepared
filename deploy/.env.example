# -----------------------------------------------------------------------
# bePrepared — environment variables
# Copy this file to deploy/.env and fill in values before first start.
# NEVER commit deploy/.env to version control.
# -----------------------------------------------------------------------

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=beprepared
DB_USER=bpuser
# Change this to a strong password
DB_PASSWORD=changeme
# MariaDB root password (used only by the db container)
DB_ROOT_PASSWORD=changeme-root

# Drizzle / API connection string (must match above)
DATABASE_URL=mysql://bpuser:changeme@127.0.0.1:3306/beprepared

# --- API ---
PORT=3001
NODE_ENV=production

# --- Authentication ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret
# Internal URL the frontend uses to reach the API for auth (inside the pod)
NEXTAUTH_API_URL=http://localhost:3001
# Optional: override default admin seed password (default: changeme)
SEED_ADMIN_PASSWORD=changeme

# --- Frontend ---
# URL the browser uses to reach the API (external / published)
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Ports (published to host) ---
# Frontend
FRONTEND_PORT=9999
# phpMyAdmin
PMA_PORT=9998

# --- phpMyAdmin ---
# Blowfish secret for session cookie encryption — MUST be 32+ random chars
# Generate: openssl rand -base64 32
PMA_BLOWFISH_SECRET=replace-with-32-plus-random-chars
