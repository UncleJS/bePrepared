{
  "name": "beprepared",
  "private": true,
  "version": "0.1.0",
  "description": "Disaster preparedness system — household readiness from 72h to 90-day self-sufficiency",
  "workspaces": [
    "frontend",
    "api",
    "worker",
    "shared",
    "e2e"
  ],
  "scripts": {
    "dev:api": "bun run --cwd api dev",
    "dev:worker": "bun run --cwd worker dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "build:api": "bun run --cwd api build",
    "build:frontend": "bun run --cwd frontend build",
    "typecheck": "bun run --cwd api typecheck && bun run --cwd worker typecheck && bun run --cwd frontend typecheck && bun run --cwd shared typecheck",
    "lint:mermaid": "bun run scripts/lint-mermaid.js",
    "lint": "bun run --cwd frontend lint && bun run lint:mermaid",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "db:push": "bun run --cwd api db:push",
    "db:migrate": "bun run --cwd api db:migrate",
    "db:seed": "bun run --cwd api db:seed",
    "test": "bun run --cwd api test && bun run --cwd frontend test && bun run --cwd shared test",
    "test:e2e": "bun run --cwd e2e test",
    "test:e2e:ui": "bun run --cwd e2e test:ui",
    "test:e2e:install": "bun run --cwd e2e install",
    "test:e2e:install:ci": "bun run --cwd e2e install:ci",
    "test:e2e:merge": "bun run --cwd e2e merge-reports"
  },
  "license": "CC-BY-NC-SA-4.0",
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
