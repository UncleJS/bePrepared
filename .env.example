# -----------------------------------------------------------------------
# bePrepared — environment variables
# Canonical env file. Copy to .env and fill in real values before use.
#   cp .env.example .env
# NEVER commit .env to version control.
# -----------------------------------------------------------------------

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=beprepared
DB_USER=bpuser
# Change this to a strong password
DB_PASSWORD=changeme
# MariaDB root password (used only by the db container)
DB_ROOT_PASSWORD=changeme-root

# MariaDB container variables (mirror values above)
MARIADB_DATABASE=beprepared
MARIADB_USER=bpuser
MARIADB_PASSWORD=changeme
MARIADB_ROOT_PASSWORD=changeme-root

# Drizzle / API connection string (must match above)
DATABASE_URL=mysql://bpuser:changeme@127.0.0.1:3306/beprepared

# --- API ---
PORT=9996
NODE_ENV=production

# --- Authentication ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret
# Optional explicit API signing secret (falls back to AUTH_SECRET if unset)
API_AUTH_SECRET=
# Enable API bearer-token protection
# Must remain true in production.
AUTH_ENABLED=true
# Login rate limit window (ms) and max attempts per window (per IP+username)
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
AUTH_LOGIN_RATE_LIMIT_MAX=5
# Comma-separated CORS origins allowed to call API
CORS_ORIGINS=http://localhost:9997
# Production safety override (set true only for intentional localhost-only deployments)
ALLOW_LOCALHOST_CORS_IN_PRODUCTION=false
# REQUIRED in production: set a strong admin seed password
SEED_ADMIN_PASSWORD=replace-with-strong-password

# --- Frontend ---
# URL the browser uses to reach the API (external / published)
# Must be set at Vite build time (baked into the JS bundle)
VITE_API_URL=http://localhost:9996

# --- Worker ---
# Alert worker run interval in milliseconds (default: 900000 = 15 minutes)
WORKER_INTERVAL_MS=900000

# --- Ports (published to host) ---
# Dev:  frontend=9997, api=9996
# Prod: frontend=9999, api=9995, phpMyAdmin=9998
# FRONTEND_PORT is not consumed by any container — kept here for operator reference only.
# FRONTEND_PORT=9997
