# -----------------------------------------------------------------------
# bePrepared — .gitignore
# -----------------------------------------------------------------------

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Build outputs ---
dist/
build/
.next/
out/

# --- Bun ---
bun.lockb

# --- Environment / secrets ---
.env
.env.*
.env.local
.env.*.local
!.env.example
deploy/.env
deploy/secrets/*
!deploy/secrets/.gitkeep
*.enc
*.pem
*.key
*.p12
*.pfx
*.kdbx
*credentials*
*credential*
*password*
*passwd*
*secret*
**/*credentials*.json
**/*credentials*.yml
**/*credentials*.yaml
**/*credentials*.toml
**/*credentials*.ini
**/*password*.json
**/*password*.yml
**/*password*.yaml
**/*password*.toml
**/*password*.ini

# --- Database data volume ---
data/

# --- Drizzle generated migrations (keep the folder, ignore nothing here)
# migrations are intentionally committed — remove this section if you prefer
# api/src/db/migrations/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Healthcheck log directory ---
# Keep the directory in git but ignore the log files written at runtime.
logs/*.log
!logs/.gitkeep

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Testing ---
coverage/
.nyc_output/
e2e/.auth/
playwright-report/
test-results/
blob-report/

# --- Podman / container artefacts ---
# (quadlet units and Containerfiles are intentionally committed)
